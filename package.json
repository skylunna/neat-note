{
  "name": "neat-note",
  "displayName": "neat-note",
  "publisher": "ZhengTianlun",
  "icon": "assets/icon.png",
  "description": "clear code comments and std it",
  "version": "0.1.3", 
  "engines": {
    "vscode": "^1.110.0"
  },
  "repository": {
  "type": "git",
  "url": "https://github.com/skylunna/neat-note.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": ["onLanguage:python"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "python",
        "extensions": [".py"],
        "aliases": ["Python"]
      }
    ],
    "commands": [
      {
        "command": "neat-note.normalize",
        "title": "Neat Note: Normalize Comments"
      }
    ],
    "configuration": {
      "title": "Neat Note",
      "properties": {
        "neat-note.removeEmoji": {
          "type": "boolean",
          "default": true,
          "description": "是否移除注释中的Emoji表情"
        },
        "neat-note.fixSpacing": {
          "type": "boolean",
          "default": true,
          "description": "是否修复 # 后的空格 (如 #fix -> # fix)"
        },
        "neat-note.normalizeSpaces": {
            "type": "boolean",
            "default": true,
            "description": "是否将多个空格/Tab 规范化为单个空格"
        },
        "neat-note.trimTrailingSpaces": {
            "type": "boolean",
            "default": true,
            "description": "是否移除注释末尾的空格"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "emoji-regex": "^10.6.0"
  }
}
